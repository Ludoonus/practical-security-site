---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.status !== 'draft' || true)
  .sort((a, b) => {
    const dateA = new Date(a.data.pubDate ?? a.data.date ?? 0);
    const dateB = new Date(b.data.pubDate ?? b.data.date ?? 0);
    return dateB.valueOf() - dateA.valueOf();
  });
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section>
        <h1>Practical Security Guides</h1>
        <p>Hands-on offensive security, penetration testing, and cert prep — no fluff.</p>
        <ul>
          {posts.map(post => (
            <li>
              <a href={'/blog/' + post.id + '/'}>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <time datetime={(post.data.pubDate ?? post.data.date ?? new Date()).toString()}>
                  {new Date(post.data.pubDate ?? post.data.date ?? new Date()).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
<style>
  main { max-width: 720px; margin: 0 auto; padding: 2rem 1rem; }
  h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  ul { list-style: none; padding: 0; margin-top: 2rem; }
  li { border-bottom: 1px solid #eee; padding: 1.5rem 0; }
  li:first-child { padding-top: 0; }
  a { text-decoration: none; color: inherit; }
  a:hover h2 { text-decoration: underline; }
  h2 { font-size: 1.3rem; margin: 0 0 0.4rem; }
  p { color: #555; margin: 0 0 0.4rem; font-size: 0.95rem; }
  time { font-size: 0.85rem; color: #999; }
</style>
